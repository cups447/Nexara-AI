BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
TELEGRAM_ADMIN_IDS=123456789,987654321

DATABASE_URL=sqlite:///./nexara.db
DATABASE_ECHO=false

SCAN_INTERVAL_SECONDS=30
MIN_VOLUME_USDT=1000000
MIN_CONFIDENCE_SCORE=90
MAX_PAIRS_TO_SCAN=200

SIGNAL_COOLDOWN_MINUTES=60
MAX_SIGNALS_PER_HOUR=10
DEFAULT_RISK_PERCENT=1.0
DEFAULT_LEVERAGE=10

MAX_RISK_PER_TRADE=2.0
MIN_RISK_REWARD=2.0
ATR_SL_MULTIPLIER=1.5
ATR_TP1_MULTIPLIER=1.5
ATR_TP2_MULTIPLIER=3.0
ATR_TP3_MULTIPLIER=5.0

API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_long_random_secret_key
API_WORKERS=1

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

LOG_LEVEL=INFO
LOG_FILE=logs/nexara.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

COINGECKO_API_URL=https://api.coingecko.com/api/v3
ALTERNATIVE_ME_API_URL=https://api.alternative.me/fng/
CRYPTO_NEWS_API_KEY=your_cryptonews_api_key_here
CRYPTO_NEWS_API_URL=https://cryptonews-api.com/api/v1

ENVIRONMENT=production
DEBUG=false
